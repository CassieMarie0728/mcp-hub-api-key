{
  "$schema": "https://registry.scalar.com/@scalar/schemas/config",
  "scalar": "2.0.0",
  "metadata": {
    "title": "MCP Hub API Reference",
    "description": "Developer documentation and interactive API reference for the MCP Hub API runtime.",
    "ogTitle": "MCP Hub API Reference",
    "ogDescription": "Explore the MCP Hub API endpoints, authentication, lifecycle flows, tools, resources, prompts, events, and connection management."
  },
  "theme": "kepler",
  "darkMode": true,
  "navigation": {
    "header": [
      { "type": "link", "title": "Home", "to": "/" },
      { "type": "link", "title": "API Reference", "to": "/api" },
      { "type": "spacer" },
      { "type": "link", "title": "GitHub", "to": "https://github.com/CassieMarie0728/mcp-hub-api-key", "newTab": true }
    ],
    "tabs": [
      { "title": "Docs", "path": "/", "icon": "phosphor/regular/book-open" },
      { "title": "API", "path": "/api", "icon": "phosphor/regular/plug" }
    ],
    "sidebar": [
      { "title": "GitHub Repository", "url": "https://github.com/CassieMarie0728/mcp-hub-api-key", "icon": "phosphor/regular/github-logo", "newTab": true }
    ],
    "routes": {
      "/": {
        "type": "page",
        "title": "Introduction",
        "filepath": "README.md",
        "description": "Overview, setup notes, features, and basic usage for MCP Hub API.",
        "icon": "phosphor/regular/house"
      },
      "/api": {
        "type": "openapi",
        "title": "API Reference",
        "filepath": "v1.0/cassiemarieauthor-MCPHUB_API_KEY-2.0.0-resolved.yaml",
        "mode": "nested",
        "icon": "phosphor/regular/plug",
        "config": {
          "theme": "kepler",
          "layout": "modern",
          "darkMode": true,
          "hideDarkModeToggle": false,
          "showSidebar": true,
          "hideDownloadButton": false,
          "hideModels": false,
          "searchHotKey": "k",
          "defaultHttpClient": { "targetKey": "shell", "clientKey": "curl" },
          "servers": [
            { "url": "https://api.mcphub.example.com/v1", "description": "Production MCP Hub API" },
            { "url": "http://localhost:8080/v1", "description": "Local Development MCP Hub API" }
          ],
          "authentication": {
            "preferredSecurityScheme": "BearerAuth",
            "securitySchemes": {
              "BearerAuth": { "token": "${MCP_API_KEY}" }
            }
          },
          "customCss": ":root {\n  --scalar-color-accent: #981518;\n  --scalar-background-1: #0b0f0f;\n  --scalar-background-2: #111717;\n  --scalar-background-3: #171d1d;\n  --scalar-color-1: #f4f4f4;\n  --scalar-color-2: #a8a9ad;\n  --scalar-border-color: rgba(168, 169, 173, 0.22);\n}\n"
        }
      },
      "/architecture": {
        "type": "page",
        "title": "Architecture",
        "filepath": "docs/mcp-hub-api-documentation.md",
        "description": "MCP Hub API architecture and implementation guide.",
        "icon": "phosphor/regular/flow-arrow"
      },
      "/code-summary": {
        "type": "page",
        "title": "Code Summary",
        "filepath": "docs/mcp-hub-api-code-summary.md",
        "description": "Code-oriented summary of the MCP Hub API.",
        "icon": "phosphor/regular/code"
      },
      "/terms": {
        "type": "page",
        "title": "Terms of Service",
        "filepath": "policies/terms-of-service.md",
        "description": "Terms of service for MCP Hub API Key.",
        "icon": "phosphor/regular/file-text"
      }
    }
  }
}
